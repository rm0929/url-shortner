# DO NOT COMMIT the real secrets.yaml
# Copy this file to secrets.yaml and fill in real values
# secrets.yaml is in .gitignore

apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: url-shortener
type: Opaque
stringData:
  DATABASE_URL: "postgresql+asyncpg://user:pass@host:5432/urlshortener"
  REDIS_URL: "redis://your-elasticache-endpoint:6379"
  SQS_QUEUE_URL: "https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/click-events"
  AWS_ACCESS_KEY_ID: "your-access-key"
  AWS_SECRET_ACCESS_KEY: "your-secret-key"
  ANALYTICS_DATABASE_URL: "postgresql://user:pass@host:5432/analytics"
